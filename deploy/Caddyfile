# Caddy block for libre.academy. Drop into /etc/caddy/Caddyfile on
# the production VPS (or include it from there). Caddy auto-issues a
# Let's Encrypt cert as soon as DNS points at this box.
#
# Mirrors the layout of the mattssoftware.com block — same VPS, same
# Caddy install, just a separate site block per domain.

www.libre.academy {
    redir https://libre.academy{uri} permanent
}

libre.academy {
    root * /var/www/libre-academy
    encode zstd gzip

    # ── Embedded learn app ──────────────────────────────────────────
    #
    # The kata `dist-web/` tree lives under /learn/. Real assets are
    # served directly; deep paths (e.g. /learn/courses/foo) fall
    # through to the embed's own index.html so kata's React Router
    # handles the route without dropping into the marketing SPA.
    @learn path /learn /learn/*
    handle @learn {
        try_files {path} /learn/index.html
        file_server
    }

    # ── Starter courses JSON ────────────────────────────────────────
    #
    # Course detail pages on the marketing site lazy-fetch from
    # /starter-courses/<id>.json. They're plain JSON files; let
    # them be cacheable for a day.
    @courses path /starter-courses/*
    handle @courses {
        header Cache-Control "public, max-age=86400, immutable"
        file_server
    }

    # ── SPA-only utility routes ──────────────────────────────────────
    #
    # These aren't prerendered public landing pages; they need the React
    # app shell so the client router can hydrate the right screen.
    @spa path /oauth/done /reset-password /verify-email /pricing /audit /donate
    handle @spa {
        rewrite * /index.html
        file_server
    }

    # ── Marketing site (prerendered HTML) ────────────────────────────
    #
    # Public pages are emitted as flat HTML files by scripts/prerender.mjs.
    # We intentionally DO NOT fall back to /index.html here; unknown paths
    # should be real HTTP 404s for crawlers and browsers alike.
    handle {
        try_files {path} {path}.html {path}/index.html
        file_server
    }

    handle_errors {
        @notfound expression `{http.error.status_code} == 404`
        handle @notfound {
            rewrite * /404.html
            header Cache-Control "no-store"
            file_server
        }
    }

    # Optional: emit standard access logs to journalctl. Useful for
    # debugging; comment out in environments that don't want logs.
    log {
        output stdout
        format console
    }
}

# Pre-cutover testing block. Keep until DNS points at this box and
# the cert is issued, then drop. Resolves to the VPS's IP via nip.io.
# fishbones-test.149.28.120.197.nip.io:80 {
#     root * /var/www/libre-academy
#     encode zstd gzip
#     try_files {path} /index.html
#     file_server
# }
